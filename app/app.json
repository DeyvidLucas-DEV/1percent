{
  "expo": {
    "name": "1%",
    "slug": "app-1-percent",
    "scheme": "umporcento",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.umporcento.app",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "umporcento"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.863364734205-pauis7u6qhm56rqtq76uv6d24vc94lac"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.umporcento.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-notifications",
      "expo-web-browser",
      "expo-font",
      [
        "expo-audio",
        {
          "microphonePermission": "O 1% usa o microfone pra você gravar relatos por voz no Diário."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
